{
  "$schema": "node_modules/wrangler/config-schema.json",
  // Source-of-truth Worker config mirrored into zb-content.api-v2.02/wrangler.jsonc by scripts/release-sync.mjs.
  // Required Worker secrets:
  // - OPENAI_API_KEY
  // - SHOPIFY_CLIENT_ID
  // - SHOPIFY_CLIENT_SECRET
  // - META_PAGE_ACCESS_TOKEN
  // - PUBLISH_ADMIN_TOKEN
  "name": "zb-content-api",
  "main": "worker.js",
  "compatibility_date": "2026-05-03",
  "observability": {
    "enabled": true
  },
  // Create this R2 bucket before deploying the Worker, or change the bucket name to your chosen value.
  "r2_buckets": [
    {
      "binding": "REFERENCE_LIBRARY",
      "bucket_name": "zb-marketing-reference-library"
    }
  ],
  "compatibility_flags": [
    "nodejs_compat"
  ]
}
